Options -Indexes
Options -ExecCGI

# 芒鈥濃偓芒鈥濃偓 Block direct HTTP access to the includes/ subdirectory 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓
# FilesMatch alone won't catch directory requests; combine with a redirect rule.
<FilesMatch "^includes/">
    Order deny,allow
    Deny from all
</FilesMatch>

<IfModule mod_authz_core.c>
    # Apache 2.4+
    <Directory "includes">
        Require all denied
    </Directory>
</IfModule>

<IfModule !mod_authz_core.c>
    # Apache 2.2 fallback
    <Directory "includes">
        Order deny,allow
        Deny from all
    </Directory>
</IfModule>

# 芒鈥濃偓芒鈥濃偓 Block access to raw PHP includes via URL rewriting 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Deny direct requests to includes/
    RewriteRule ^includes/ - [F,L]

    # 芒鈥濃偓芒鈥濃偓 Uncomment to force HTTPS in production 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# 芒鈥濃偓芒鈥濃偓 Prevent clickjacking / MIME sniffing via headers 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# PHP limits
php_value upload_max_filesize 2G
php_value post_max_size 2G
php_value max_execution_time 600
php_value max_input_time 600
